# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Google Analytics 4
GA4_PROPERTY_ID=123456789
GA4_CREDENTIALS_PATH=./credentials/ga4-service-account.json

# Google Search Console
GSC_SITE_URL=https://www.lathampool.com

# CallRail (optional)
CALLRAIL_API_KEY=
CALLRAIL_ACCOUNT_ID=

# QR Code Tracking (optional)
FLOWCODE_API_KEY=
BITLY_ACCESS_TOKEN=

# SEMrush (optional)
SEMRUSH_API_KEY=

# App Config
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]
